# Copy to /etc/wormhole/wormhole.env and fill in values.

SECRET_KEY=replace-with-long-random-secret
DATABASE_URL=postgresql://username:password@db-host:5432/dbname

# HTTPS and cookie settings expected by app config
FORCE_HTTPS=1
ENABLE_HSTS=1
SESSION_COOKIE_SECURE=1
PREFERRED_URL_SCHEME=https

# Optional local fallback behavior (normally keep disabled in production)
# ALLOW_SQLITE_FALLBACK=0
