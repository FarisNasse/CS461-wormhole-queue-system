# Copy to /etc/wormhole/wormhole.env and fill in values.

# Choose one database configuration.

# PostgreSQL example
SECRET_KEY=replace-with-long-random-secret
DATABASE_URL=postgresql://username:password@db-host:5432/dbname

# SQLite example on the same EC2 instance
# DATABASE_URL=sqlite:////home/ec2-user/CS461-wormhole-queue-system/app.db
# Or use the built-in SQLite fallback instead of DATABASE_URL:
# ALLOW_SQLITE_FALLBACK=1

# HTTPS and cookie settings expected by app config
FORCE_HTTPS=1
ENABLE_HSTS=1
SESSION_COOKIE_SECURE=1
PREFERRED_URL_SCHEME=https
